{
  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,

    "types": ["node"],

    "sourceMap": true,
    "inlineSources": true,

    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/utils/*"],
      "@/*": ["src/*"]
    },

    "noEmitOnError": true,
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.node"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
