{
  "name": "task-notes-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:prep": "sudo service postgresql start && sudo service redis-server start",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "test": "vitest run --exclude \"dist/**\"",
    "test:watch": "vitest --exclude \"dist/**\"",
    "test:coverage": "vitest run --coverage --exclude \"dist/**\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "drizzle-kit drop && npm run db:migrate && npm run db:seed",
    "db:backup": "pg_dump -Fc $DATABASE_URL -f ./data/backups/backup-$(date +%s).sql",
    "db:restore": "pg_restore -c -d $DATABASE_URL ./data/backups/$1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitest/coverage-v8": "^4.0.7",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.20.1",
    "msw": "^2.12.12",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}